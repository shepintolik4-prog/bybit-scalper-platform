[Unit]
Description=Bybit Scalper FastAPI backend
After=network.target postgresql.service

[Service]
Type=simple
User=scalper
WorkingDirectory=/opt/scalper/backend
EnvironmentFile=-/opt/scalper/backend/.env
ExecStart=/opt/scalper/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
