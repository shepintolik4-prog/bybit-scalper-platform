# === База данных (Docker: совпадает с docker-compose) ===
DATABASE_URL=postgresql+psycopg2://scalper:scalper@db:5432/scalper

# Локальный запуск backend без Docker:
# DATABASE_URL=postgresql+psycopg2://scalper:scalper@localhost:5433/scalper

# === Шифрование ключей в БД (Fernet); обязателен при использовании POST /api/keys/bybit ===
SECRET_KEY=change-me-min-16-chars-for-fernet

# === Bybit (testnet: https://testnet.bybit.com) — fallback, если ключи не заданы через UI ===
BYBIT_API_KEY=
BYBIT_API_SECRET=
# mainnet для публичных свечей (рекомендуется для paper-скана)
BYBIT_TESTNET=false

# === Режим реальной торговли (двойная защита) ===
# Должно быть явно true для live-ордеров
CONFIRM_REAL_TRADING=false

# === Sentry (опционально) ===
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0

# === Метрики DogStatsD → Datadog Agent (UDP) ===
# Локально с docker-compose.datadog.yml: METRICS_ENABLED=true, DD_AGENT_HOST=datadog
METRICS_ENABLED=false
DD_AGENT_HOST=
DD_DOGSTATSD_PORT=8125
METRICS_PREFIX=bybit_scalper
# Пример: env:dev,region:eu (через запятую key:value)
METRICS_DEFAULT_TAGS=

# Datadog Agent (только для compose-файла docker-compose.datadog.yml)
DD_API_KEY=
DD_SITE=datadoghq.com

# === CORS (для локального фронта) ===
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# === Секрет API бэкенда (для смены режима real) ===
API_SECRET=change-me-in-production

# DEBUG=true: при старте автоматически bot_enabled=true в paper (удобно для dev)
DEBUG=true

# === ML / бот (paper dev — активный скан и мягкие пороги) ===
MODEL_DIR=models
DEFAULT_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT
# SCAN_ALL_ENABLED или SCAN_ALL_USDT_PERPETUAL
SCAN_ALL_ENABLED=true
SCAN_ALL_SYMBOLS_REFRESH_SEC=3600
SCAN_ALL_MAX_SYMBOLS=30
# Пустые свечи с Bybit → синтетика (только разработка)
MOCK_OHLCV_ON_EMPTY=false
# Нет сделок в paper дольше N сек → ослабление фильтров на тик
PAPER_QUIET_FALLBACK_SEC=600
# Сканер: мин. 24h quote volume USDT (0 = не фильтровать)
SCANNER_MIN_QUOTE_VOLUME_USDT=0
SCANNER_MAX_PARALLEL=12
SCANNER_LIQUIDITY_REF_QUOTE_VOL=5000000
# 0 = выкл.; отсев пар с подозрительно малой ценой/объёмом последней свечи
SCANNER_MIN_CLOSE_USDT=0
SCANNER_MIN_LAST_BAR_VOLUME=0
OHLCV_CACHE_TTL_SEC=45
# Выбор сделки: max(composite) = |edge|×conf×ликвидность×риск_ATR
SELECTION_USE_COMPOSITE=true
TRADE_OUTCOMES_PATH=data/trade_outcomes.jsonl
SCAN_INTERVAL_SEC=60
# При bot_enabled=false: как часто проверять TP/SL/принудительные выходы (позиции иначе не закрываются)
MANAGE_POSITIONS_POLL_SEC=8
# Сколько лучших кандидатов (после дедупа по символу) пробовать открыть за один тик
MAX_CANDIDATES_PER_TICK=15
MAX_OPEN_POSITIONS=3
RISK_PER_TRADE_PCT=1.0
MAX_DRAWDOWN_PCT=15.0
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=10

# Фильтры сигнала и риск (алиасы env: MIN_EDGE → SIGNAL_MIN_EDGE, MIN_CONFIDENCE → MIN_MODEL_CONFIDENCE)
SIGNAL_MIN_EDGE=0.0
MIN_MODEL_CONFIDENCE=0.5
MIN_RISK_REWARD=1.05
ATR_PCT_MIN=0.0008
ATR_PCT_MAX=0.035
# USE_ATR_FILTER=false: ATR не режет сигналы, только множитель atr_score в composite (мягкая зона ATR_SOFT_*)
USE_ATR_FILTER=false
ATR_SOFT_OPT_MIN_PCT=0.005
ATR_SOFT_OPT_MAX_PCT=0.03
ATR_SOFT_SCORE_FLOOR=0.18
USE_MACD_MOMENTUM_FILTER=false
MAX_MARGIN_PCT_EQUITY=0.22
DAILY_LOSS_LIMIT_PCT=5.0
MIN_EQUITY_USDT=20

# Ослабить пороги (ATR-диапазон, edge, meta, ликвидность) и чаще пропускать flat/ATR при rule-fallback
AGGRESSIVE_MODE=false
# При коротком strict/recovered — EMA/breakout/volume (см. fallback_strategy)
FALLBACK_RULE_ENABLED=true
# Мин. строк во фрейме после strict или recovered (ниже — fallback или отказ)
FEATURE_FRAME_MIN_ROWS=28

# --- Агрессивный скальпинг (высокий риск): см. docs/scalping_aggressive.example.yaml ---
AGGRESSIVE_SCALPING_MODE=false
SCALPING_SCAN_TIMEFRAME=1m
SCALPING_OHLCV_LIMIT=420
SCALPING_MIN_OHLCV_BARS=48
SCALPING_MAX_OPEN_POSITIONS=12
SCALPING_RISK_PER_TRADE_PCT=3.0
SCALPING_DEFAULT_LEVERAGE=15
SCALPING_MAX_LEVERAGE_CAP=20
SCALPING_SL_PCT=0.007
SCALPING_TP_PCT=0.014
SCALPING_FORCE_TRADE_AFTER_MINUTES=20
SCALPING_MAX_TRADES_PER_MINUTE=36

# --- MAX FLOW / HFT-style (ОЧЕНЬ высокий риск): все USDT linear perpetual, 4 rule-стратегии, минимум фильтров ---
# Включает скан всех пар (игнорирует DEFAULT_SYMBOLS), при старте API поднимает bot_enabled и лимиты в БД (если AUTO_ENABLE).
FULL_AGGRESSIVE_MAX_FLOW=false
FULL_AGGRESSIVE_AUTO_ENABLE_BOT=true
FULL_AGGRESSIVE_MAX_POSITIONS=40
FULL_AGGRESSIVE_RISK_PCT=2.0
FULL_AGGRESSIVE_MIN_LEVERAGE=10
FULL_AGGRESSIVE_MAX_LEVERAGE=20
FULL_AGGRESSIVE_SL_PCT=0.01
FULL_AGGRESSIVE_TP_PCT=0.012
FULL_AGGRESSIVE_SCAN_TIMEFRAME=1m
FULL_AGGRESSIVE_OHLCV_LIMIT=220
FULL_AGGRESSIVE_MIN_OHLCV_BARS=28
FULL_AGGRESSIVE_FORCE_TRADE=true
FULL_AGGRESSIVE_FORCE_TRADE_SEC=60
FULL_AGGRESSIVE_MAX_TRADES_PER_MINUTE=72
FULL_AGGRESSIVE_TRADE_CSV_PATH=data/trades_detailed.csv
# После 100+ сделок (сумма по стратегиям в strategy_stats): отключить стратегии с WR<40% и отрицательным PnL; boost топ-20% по PnL
FULL_AGGRESSIVE_AUTO_SELECT_MIN_TRADES=100

# === Preset: FULL AUTO / max-flow + скальпинг (все USDT perp, много входов за тик; только paper до live) ===
# SCAN_ALL_USDT_PERPETUAL=true
# SCAN_INTERVAL_SEC=45
# MAX_CANDIDATES_PER_TICK=15
# FULL_AGGRESSIVE_MAX_FLOW=true
# AGGRESSIVE_SCALPING_MODE=true
# MAX_OPEN_POSITIONS=24
# SCALPING_MAX_OPEN_POSITIONS=24
# FULL_AGGRESSIVE_MAX_POSITIONS=40
# SIGNAL_MIN_EDGE=0.01
# MIN_MODEL_CONFIDENCE=0.50
# USE_MACD_MOMENTUM_FILTER=false
# USE_ATR_FILTER=false
# META_ENABLED=false
# FULL_AGGRESSIVE_FORCE_TRADE=true
# FULL_AGGRESSIVE_FORCE_TRADE_SEC=60
# FULL_AGGRESSIVE_MAX_TRADES_PER_MINUTE=72

# Regime / исполнение / динамический риск / корреляции / meta / WF
LOG_LEVEL=INFO
REGIME_ADX_TREND=22
REGIME_ATR_HIGH_PCT=0.028
REGIME_VOL_CLUSTER_HIGH=1.65
REGIME_FLAT_TRADE_ALLOW=0.55
EXEC_SPREAD_BPS=2
EXEC_SLIPPAGE_BPS=3
EXEC_LATENCY_BARS=1
EXEC_FEE_ROUNDTRIP_PCT=0.12

# Защита позиций: таймаут, битый mark, аномальный нереализованный PnL (% с плечом как при закрытии)
# Алиас: MAX_POSITION_AGE_SEC
MAX_POSITION_LIFETIME_SEC=300
BAD_MARK_PRICE_MAX_REL_DEVIATION=0.5
POSITION_FORCE_CLOSE_PNL_PCT_HIGH=200
POSITION_FORCE_CLOSE_PNL_PCT_LOW=-80
MARK_PRICE_MAX_STALE_SEC=180
PAPER_MARK_PREFER_TICKER=true

# Live execution: сверка БД↔Bybit, failsafe подтверждение входа, reduceOnly при выходе по логике бота
EXCHANGE_SYNC_ENABLED=true
EXCHANGE_SYNC_INTERVAL_SEC=15
LIVE_ORDER_CONFIRM_TIMEOUT_SEC=12
LIVE_ORDER_CONFIRM_POLL_SEC=0.25
DYNAMIC_RISK_DD_COMPRESS=0.55
DYNAMIC_RISK_FLOOR_MULT=0.35
CORR_MAX_PAIR=0.82
MAX_TOTAL_EXPOSURE_RATIO=2.6
META_ENABLED=true
META_MIN_P_TRADE=0.45
WF_TRAIN_BARS=400
WF_TEST_BARS=80
WF_STEP_BARS=40
WF_PURGE_BARS=5

# Портфель (portfolio_manager /api/portfolio)
PORTFOLIO_SIGNAL_TEMPERATURE=1.15
PORTFOLIO_PERIODS_PER_YEAR=105120
PORTFOLIO_DEFAULT_METHOD=risk_parity_erc

# === Quant-fund / PM (концентрация, кластеры, vol overlay, ERC-выбор кандидата) ===
FUND_RISK_ENABLED=true
FUND_MAX_SINGLE_NAME_GROSS_PCT=0.52
FUND_MAX_ALT_CLUSTER_SHARE=1.0
FUND_MAJOR_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
FUND_VOL_TARGETING_ENABLED=false
FUND_VOL_REL_THRESHOLD=0.0012
FUND_VOL_SIZE_SCALE_FLOOR=0.55
FUND_PORTFOLIO_TILT_ENABLED=false
FUND_PORTFOLIO_TILT_METHOD=risk_parity_erc
FUND_TILT_W_MAX=0.48
FUND_TILT_MAX_PAIR_CORRELATION=0.88

# === Автономный контур (новости, HF sentiment, Langfuse, Prometheus, self-improve, auto-retrain) ===
NEWS_ENABLED=false
# Запятая: URL для Firecrawl scrape (markdown)
NEWS_URLS=https://www.coindesk.com/,https://cointelegraph.com/
FIRECRAWL_API_KEY=
HF_TOKEN=
HF_SENTIMENT_ENABLED=false
HF_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
NEWS_SENTIMENT_SCALE=0.06
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
PROMETHEUS_METRICS_PATH=/metrics
BROWSERBASE_ENABLED=false
BROWSERBASE_API_KEY=
BROWSERBASE_WS_ENDPOINT=
AUTO_RETRAIN_ENABLED=false
AUTO_RETRAIN_INTERVAL_HOURS=24
SELF_IMPROVE_ENABLED=false
SELF_IMPROVE_INTERVAL_SEC=3600
SELF_IMPROVE_WINDOW_HOURS=24
SELF_IMPROVE_MIN_TRADES=8
SELF_IMPROVE_WINRATE_LOW=0.38
SELF_IMPROVE_WINRATE_HIGH=0.58
SELF_IMPROVE_BIAS_STEP=0.004
SELF_IMPROVE_BIAS_MAX=0.025
ADAPTIVE_STATE_PATH=data/adaptive_state.json

# === Мульти-стратегии + smart pause + алерты + watchdog ===
MULTI_STRATEGY_ENABLED=true
STRATEGY_ROUTER_MODE=regime
# regime | ml_only
STRATEGY_ML_CONF_FLOOR=0.5
MEAN_REVERSION_Z_THRESHOLD=1.55
MEAN_REVERSION_TP_SCALE=0.62
BREAKOUT_VOL_CLUSTER_MIN=1.35
BREAKOUT_VOLUME_MULT=1.18
BREAKOUT_TP_SCALE=1.05
STRATEGY_STATS_PATH=data/strategy_stats.json
STRATEGY_MIN_TRADES_FOR_DISABLE=15
STRATEGY_MIN_WINRATE_DISABLE=0.28
TRADING_CONTROL_PATH=data/trading_control.json
SMART_PAUSE_DRAWDOWN_PCT=0
SMART_PAUSE_EQUITY_VOL_MULT=0
SMART_PAUSE_AUTO_CLEAR_SEC=0
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_LOG_PATH=data/alerts.log
WATCHDOG_ENABLED=false
WATCHDOG_API_BASE=http://127.0.0.1:8000
WATCHDOG_INTERVAL_SEC=60
WATCHDOG_READY_TIMEOUT_SEC=12
WATCHDOG_NO_TRADE_SEC=14400
WATCHDOG_MAX_TICK_SEC=180
WATCHDOG_RESTART_CMD=

# === Production engine: kill switch, guards, consistency, profit layer ===
# Kill switch — пауза новых входов (trading_control source=kill_switch)
KILL_SWITCH_ENABLED=false
KILL_SWITCH_DRAWDOWN_PCT=35
KILL_SWITCH_EXCHANGE_ERRORS_WINDOW_N=8
KILL_SWITCH_EXCHANGE_ERRORS_WINDOW_SEC=120
KILL_SWITCH_ATR_SPIKE_RATIO=2.5
KILL_SWITCH_MIN_EQUITY_USDT=0
# Лимит частоты входов и экспозиции на символ (notional/equity)
MAX_TRADES_PER_MINUTE=12
MAX_EXPOSURE_PER_SYMBOL_RATIO=1.2
CIRCUIT_BREAKER_WINDOW_SEC=180
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_SEC=300
CONSISTENCY_CHECKS_ENABLED=true
CONSISTENCY_CHECK_INTERVAL_TICKS=30
# Profit engine (динамический edge/confidence floor через adaptive_state — см. код)
PROFIT_DIVERSIFICATION_ENABLED=true
PROFIT_ADAPTIVE_LEARNING_ENABLED=true
PROFIT_ADAPTIVE_INTERVAL_SEC=3600
